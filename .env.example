# Stripe — OPTIONAL.
# The funnel works WITHOUT these (it falls back to a built-in mock checkout page).
# To use a REAL Stripe test checkout, add your TEST-mode secret key here.
# Get one at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# The public URL of the deployed site (used for Stripe success/cancel redirects).
# Locally this can be left blank — it defaults to the request origin.
NEXT_PUBLIC_SITE_URL=
